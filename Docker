NODE-DOCKERFILE
-----------------
FROM node AS builder
WORKDIR shasi/
COPY package*.json .
RUN npm install
COPY . .
RUN npm run build
FROM nginx
COPY --from=builder /shasi/dist/ /usr/share/nginx/html/
CMD ["nginx", "-g", "daemon off;"]
