Basic Pipeline syntax :
pipeline {
    agent any
    stages {
        stage ("code") {
            steps {
                echo "Welcome to My first pipeline type job"
            }
        }
    }
}


========================================================================================================================================================

Multi stage pipeline :

pipeline {
    agent any
    stages {
        stage ("code") {
            steps {
                echo "Welcome to My first pipeline type job"
            }
        }
        stage ("Build") {
            steps {
                echo "This is build stage"
            }
        }
        stage ("Test") {
            steps {
                echo "This is testing stage"
            }
        }
    }
}

