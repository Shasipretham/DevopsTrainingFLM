pipeline {
    agent any

    stages {
        stage('code') {
            steps {
                git 'https://github.com/sreenadh45/nginx.git'
                 
            }
        }
        stage('build'){
            steps{
                sh "docker build -t app2 ."
            }
            
        }
        stage('registry'){
            steps{
                script{
                    withDockerRegistry(credentialsId: 'docker reg') {
                        sh "docker tag app2 shasi5612/myrepo"
                        sh "docker push shasi5612/myrepo"
                   }
                    
                }
            }
        }
        stage('run container'){
            steps{
                sh 'docker run -d --name $conname -p $port:80 shasi5612/myrepo  '
            }
        }
    }
}

